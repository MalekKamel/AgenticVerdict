# Copy to `.env.docker` and adjust (file is gitignored). Sourced by the root Makefile via `include`.
# Do not put real production secrets here; use your secret manager or deploy-time env.

# Project / Compose
COMPOSE_PROJECT_NAME=agenticverdict

# Optional: pin image tags when using deploy/docker-compose.production.example.yml
# VERSION=latest
# REGISTRY=agenticverdict

# Host-facing ports (documented defaults; Compose files pin most ports explicitly)
WEB_PORT=3000
API_PORT=4000
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
PGADMIN_PORT=5050

# Frontend API wiring (Docker)
# Browser bundle API URL (build-time Vite variable); use host-reachable API endpoint.
VITE_PUBLIC_API_URL=http://localhost:4000
# Frontend SSR/internal API URL (runtime) from inside docker network.
FRONTEND_INTERNAL_API_URL=http://api:4000
# Default tenant UUID required by /$locale loader in current frontend implementation.
VITE_PUBLIC_DEFAULT_TENANT_ID=11111111-1111-4111-8111-111111111111

# Build
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
BUILDKIT_PROGRESS=plain

# Host DB URL for migrations from the machine (Postgres published from docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agenticverdict

# Optional pgAdmin bootstrap credentials for docker-compose.pgadmin.yml
PGADMIN_DEFAULT_EMAIL=admin@agenticverdict.dev
PGADMIN_DEFAULT_PASSWORD=change-me-local
