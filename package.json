{
  "name": "agenticverdict",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "check:cycles": "madge --circular --extensions ts,tsx packages/types/src/index.ts packages/config/src/index.ts packages/core/src/index.ts packages/database/src/index.ts packages/data-connectors/src/index.ts packages/agent-runtime/src/index.ts packages/report-generator/src/index.ts packages/i18n/src/index.ts packages/testing/src/index.ts apps/api/src/index.ts apps/worker/src/index.ts",
    "db:down": "docker compose down",
    "db:seed:test": "pnpm --filter @agenticverdict/database db:seed:test",
    "db:up": "docker compose up -d",
    "dev": "turbo run dev",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,mjs,cjs,json}\" \"packages/**/*.{ts,tsx,js,mjs,cjs,json}\" \"vitest.config.ts\" \"*.mjs\" \"package.json\" \"*.yml\" \"*.yaml\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,mjs,cjs,json}\" \"packages/**/*.{ts,tsx,js,mjs,cjs,json}\" \"vitest.config.ts\" \"*.mjs\" \"package.json\" \"*.yml\" \"*.yaml\" \".github/**/*.yml\"",
    "observability:up": "docker compose -f docker-compose.yml -f docker-compose.observability.yml up -d",
    "lint": "turbo run lint",
    "lint:openapi": "redocly lint specs/00-core/01-connectors/operations/openapi/platform-adapters-health.yaml",
    "prepare": "husky",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:web:smoke": "pnpm --filter @agenticverdict/web exec playwright test e2e/critical-path-smoke.spec.ts e2e/home-journey.spec.ts e2e/locale-smoke.spec.ts e2e/a11y-home.spec.ts e2e/api-health.optional.spec.ts --project=chromium",
    "test:integration": "turbo run test:integration",
    "test:phase01-integration": "pnpm --filter @agenticverdict/phase01-platform-integration test",
    "test:p1-report-load-matrix": "pnpm --filter @agenticverdict/api exec vitest run src/routes/v1/reports-concurrent-load-matrix.test.ts",
    "test:scenario": "tests/scripts/run-scenario.sh",
    "test:scenarios:all": "tests/scripts/run-all-scenarios.sh",
    "test:scenarios:group": "tests/scripts/run-scenario-group.sh",
    "test:production-flow": "pnpm exec vitest run tests/orchestrator --config tests/orchestrator/vitest.config.ts",
    "workflow:full": "node scripts/full-production-flow.mjs",
    "workflow:smoke:roundtrip": "node scripts/workflow-status-roundtrip-smoke.mjs",
    "test:unit": "vitest run",
    "typecheck": "turbo run typecheck",
    "verify:build-config": "pnpm exec vitest run packages/config/src/build-constants.test.ts",
    "verify:production-bundle": "NODE_ENV=production pnpm --filter @agenticverdict/api build:vite && NODE_ENV=production pnpm --filter @agenticverdict/worker build:vite && node tools/build/bundle-adapter-factory-smoke.mjs && node tools/build/analyze-bundles.mjs apps/api/dist apps/worker/dist packages/data-connectors/dist",
    "benchmark:vite-bundles": "node tools/build/benchmark-builds.mjs",
    "benchmark:performance-baseline": "node scripts/performance-baseline.mjs",
    "validate:pen-files": "python3 design/scripts/validate-pen-files.py && python3 design/scripts/validate-feature-pen-reuse.py --strict"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@agenticverdict/agent-runtime": "workspace:*",
    "@agenticverdict/config": "workspace:*",
    "@agenticverdict/data-connectors": "workspace:*",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^9.9.0",
    "@redocly/cli": "^1.28.0",
    "@types/pdf-parse": "^1.1.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vite": "^8.0.8",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jose": "^5.10.0",
    "jszip": "^3.10.1",
    "lint-staged": "^15.4.3",
    "madge": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "redis": "^4.7.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.4"
  }
}
