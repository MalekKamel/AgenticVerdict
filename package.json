{
  "name": "agenticverdict",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "check:cycles": "madge --circular --extensions ts,tsx packages/types/src/index.ts packages/config/src/index.ts packages/core/src/index.ts packages/database/src/index.ts packages/platform-adapters/src/index.ts packages/agent-runtime/src/index.ts packages/report-generator/src/index.ts packages/ui/src/index.ts packages/i18n/src/index.ts packages/testing/src/index.ts apps/api/src/index.ts apps/worker/src/index.ts",
    "db:down": "docker compose down",
    "db:up": "docker compose up -d",
    "dev": "turbo run dev",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,mjs,cjs,json}\" \"packages/**/*.{ts,tsx,js,mjs,cjs,json}\" \"vitest.config.ts\" \"*.mjs\" \"package.json\" \"*.yml\" \"*.yaml\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,mjs,cjs,json}\" \"packages/**/*.{ts,tsx,js,mjs,cjs,json}\" \"vitest.config.ts\" \"*.mjs\" \"package.json\" \"*.yml\" \"*.yaml\" \".github/**/*.yml\"",
    "lint": "turbo run lint",
    "lint:openapi": "redocly lint docs/03-development-phases/phase-01-platform-integration/operations/openapi/platform-adapters-health.yaml",
    "prepare": "husky",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo run test:e2e",
    "test:integration": "turbo run test:integration",
    "test:phase01-integration": "pnpm --filter @agenticverdict/phase01-platform-integration test",
    "test:unit": "vitest run",
    "typecheck": "turbo run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@redocly/cli": "^1.28.0",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "madge": "^8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.4"
  }
}
