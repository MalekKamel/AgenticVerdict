{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "popover-base",
      "type": "frame",
      "reusable": true,
      "children": [
        {
          "id": "popover-trigger",
          "type": "frame",
          "reusable": false,
          "layout": "horizontal",
          "padding": [8, 16],
          "cornerRadius": 8,
          "fill": "#FFFFFF",
          "stroke": {
            "thickness": 1,
            "fill": {
              "type": "color",
              "color": "#E0E0E0"
            }
          },
          "children": [
            {
              "id": "popover-trigger-label",
              "type": "text",
              "reusable": false,
              "fill": "#212121",
              "content": "Open Popover",
              "fontSize": 16
            }
          ],
          "x": 0,
          "y": 0
        },
        {
          "id": "popover-content",
          "type": "frame",
          "reusable": false,
          "layout": "vertical",
          "padding": 12,
          "cornerRadius": 8,
          "fill": "#FFFFFF",
          "stroke": {
            "thickness": 1,
            "fill": {
              "type": "color",
              "color": "#E0E0E0"
            }
          },
          "children": [
            {
              "id": "popover-heading",
              "type": "text",
              "reusable": false,
              "fill": "#212121",
              "content": "Popover Title",
              "fontSize": 18,
              "fontWeight": "600",
              "textAlign": "left"
            },
            {
              "id": "popover-body",
              "type": "text",
              "reusable": false,
              "fill": "#212121",
              "content": "Popover content goes here. You can add any content.",
              "fontSize": 14,
              "textAlign": "left"
            },
            {
              "id": "popover-footer",
              "type": "frame",
              "reusable": false,
              "layout": "horizontal",
              "gap": 8,
              "children": [
                {
                  "id": "popover-footer-cancel",
                  "type": "frame",
                  "reusable": false,
                  "layout": "horizontal",
                  "padding": [8, 16],
                  "cornerRadius": 8,
                  "stroke": {
                    "thickness": 1,
                    "fill": {
                      "type": "color",
                      "color": "#E0E0E0"
                    }
                  },
                  "children": [
                    {
                      "id": "popover-footer-cancel-label",
                      "type": "text",
                      "reusable": false,
                      "fill": "#212121",
                      "content": "Cancel",
                      "fontSize": 16
                    }
                  ]
                },
                {
                  "id": "popover-footer-confirm",
                  "type": "frame",
                  "reusable": false,
                  "layout": "horizontal",
                  "padding": [8, 16],
                  "cornerRadius": 8,
                  "fill": "#1976D2",
                  "children": [
                    {
                      "id": "popover-footer-confirm-label",
                      "type": "text",
                      "reusable": false,
                      "fill": "#FFFFFF",
                      "content": "Confirm",
                      "fontSize": 16
                    }
                  ]
                }
              ]
            }
          ],
          "x": 0,
          "y": 50
        },
        {
          "id": "popover-arrow",
          "type": "frame",
          "reusable": false,
          "height": 12,
          "width": 12,
          "fill": "#FFFFFF",
          "stroke": {
            "thickness": 1,
            "fill": {
              "type": "color",
              "color": "#E0E0E0"
            }
          },
          "x": 0,
          "y": 38
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    },
    {
      "id": "popover-base-state-default",
      "type": "ref",
      "ref": "popover-base",
      "x": 500,
      "y": 0,
      "name": "Popover/Default",
      "reusable": true
    },
    {
      "id": "popover-base-state-open",
      "type": "ref",
      "ref": "popover-base",
      "x": 500,
      "y": 100,
      "name": "Popover/Open",
      "reusable": true
    }
  ]
}
