{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "date-picker-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 8,
      "children": [
        {
          "id": "date-picker-input",
          "type": "frame",
          "reusable": false,
          "layout": "horizontal",
          "padding": [8, 12],
          "cornerRadius": 8,
          "height": 40,
          "fill": "#FFFFFF",
          "stroke": {
            "fill": "#E0E0E0",
            "thickness": 1
          },
          "children": [
            {
              "id": "date-picker-value",
              "type": "text",
              "reusable": false,
              "fill": "#9E9E9E",
              "content": "MM/DD/YYYY",
              "fontSize": 16,
              "textAlign": "left"
            }
          ]
        },
        {
          "id": "date-picker-calendar-icon",
          "type": "icon_font",
          "reusable": false,
          "fill": "#9E9E9E",
          "iconFontFamily": "lucide",
          "iconFontName": "calendar",
          "width": 20,
          "height": 20
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    }
  ]
}
