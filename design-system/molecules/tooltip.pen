{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "tooltip-base",
      "type": "frame",
      "reusable": true,
      "children": [
        {
          "id": "tooltip-trigger",
          "type": "frame",
          "reusable": false,
          "cornerRadius": 4,
          "height": 40,
          "width": 100,
          "fill": "#EEEEEE",
          "children": [
            {
              "id": "tooltip-trigger-child-0",
              "type": "text",
              "reusable": false,
              "fill": "#616161",
              "content": "Hover me",
              "fontSize": 14,
              "x": 0,
              "y": 0
            }
          ],
          "x": 0,
          "y": 0
        },
        {
          "id": "tooltip-content",
          "type": "frame",
          "reusable": false,
          "layout": "horizontal",
          "padding": [4, 8],
          "cornerRadius": 4,
          "fill": "#424242",
          "children": [
            {
              "id": "tooltip-text",
              "type": "text",
              "reusable": false,
              "fill": "#FFFFFF",
              "content": "Tooltip content",
              "fontSize": 12,
              "textAlign": "left"
            }
          ],
          "x": 0,
          "y": 0
        },
        {
          "id": "tooltip-arrow",
          "type": "frame",
          "reusable": false,
          "height": 8,
          "width": 8,
          "fill": "#424242",
          "x": 0,
          "y": 0
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    }
  ]
}
