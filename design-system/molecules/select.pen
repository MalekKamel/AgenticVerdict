{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "select-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 8,
      "padding": [8, 12],
      "cornerRadius": 8,
      "height": 40,
      "fill": "#FFFFFF",
      "stroke": {
        "fill": "#E0E0E0",
        "thickness": 1
      },
      "children": [
        {
          "id": "select-value",
          "type": "text",
          "reusable": false,
          "fill": "#9E9E9E",
          "content": "Select an option",
          "fontSize": 16,
          "textAlign": "left"
        },
        {
          "id": "select-chevron",
          "type": "icon_font",
          "reusable": false,
          "fill": "#9E9E9E",
          "iconFontFamily": "lucide",
          "iconFontName": "chevron-down",
          "width": 16,
          "height": 16
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)"
    },
    {
      "id": "select-base-state-default",
      "type": "ref",
      "ref": "select-base",
      "x": 500,
      "y": 0,
      "name": "Select/Default",
      "reusable": true
    },
    {
      "id": "select-base-state-selected",
      "type": "ref",
      "ref": "select-base",
      "x": 500,
      "y": 100,
      "name": "Select/Selected",
      "reusable": true,
      "descendants": {
        "select-value": {
          "content": "Option 1",
          "fill": "#212121"
        }
      }
    },
    {
      "id": "select-base-state-open",
      "type": "ref",
      "ref": "select-base",
      "x": 500,
      "y": 200,
      "name": "Select/Open",
      "reusable": true,
      "stroke": {
        "fill": "#1976D2",
        "thickness": 2
      }
    },
    {
      "id": "select-base-state-disabled",
      "type": "ref",
      "ref": "select-base",
      "x": 500,
      "y": 300,
      "name": "Select/Disabled",
      "reusable": true,
      "fill": "#F5F5F5",
      "opacity": 0.6
    }
  ]
}
