{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "alert-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 12,
      "padding": 12,
      "cornerRadius": 8,
      "children": [
        {
          "id": "alert-icon",
          "type": "icon_font",
          "reusable": false,
          "fill": "#757575",
          "iconFontFamily": "lucide",
          "iconFontName": "info",
          "width": 20,
          "height": 20
        },
        {
          "id": "alert-content",
          "type": "frame",
          "reusable": false,
          "layout": "vertical",
          "gap": 4,
          "children": [
            {
              "id": "alert-title",
              "type": "text",
              "reusable": false,
              "fill": "#212121",
              "content": "Alert Title",
              "fontSize": 16,
              "fontWeight": "600",
              "textAlign": "left"
            },
            {
              "id": "alert-message",
              "type": "text",
              "reusable": false,
              "fill": "#757575",
              "content": "This is an alert message with additional information.",
              "fontSize": 14,
              "textAlign": "left"
            }
          ]
        },
        {
          "id": "alert-close",
          "type": "frame",
          "reusable": false,
          "layout": "horizontal",
          "padding": [4, 8],
          "cornerRadius": 4,
          "children": [
            {
              "id": "alert-close-label",
              "type": "text",
              "reusable": false,
              "fill": "#757575",
              "content": "×",
              "fontSize": 18
            }
          ]
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    },
    {
      "id": "alert-base-info",
      "type": "ref",
      "ref": "alert-base",
      "x": 0,
      "y": 150,
      "reusable": true,
      "fill": "#E1F5FE",
      "stroke": {
        "thickness": 1,
        "fill": {
          "type": "color",
          "color": "#0288D1"
        }
      },
      "descendants": {
        "alert-icon": {
          "fill": "#0288D1",
          "iconFontName": "info"
        },
        "alert-title": {
          "fill": "#0288D1"
        },
        "alert-message": {
          "fill": "#0288D1"
        }
      }
    },
    {
      "id": "alert-base-success",
      "type": "ref",
      "ref": "alert-base",
      "x": 200,
      "y": 150,
      "reusable": true,
      "fill": "#E8F5E9",
      "stroke": {
        "thickness": 1,
        "fill": {
          "type": "color",
          "color": "#2E7D32"
        }
      },
      "descendants": {
        "alert-icon": {
          "fill": "#2E7D32",
          "iconFontName": "check-circle"
        },
        "alert-title": {
          "fill": "#2E7D32"
        },
        "alert-message": {
          "fill": "#2E7D32"
        }
      }
    },
    {
      "id": "alert-base-warning",
      "type": "ref",
      "ref": "alert-base",
      "x": 400,
      "y": 150,
      "reusable": true,
      "fill": "#FFF3E0",
      "stroke": {
        "thickness": 1,
        "fill": {
          "type": "color",
          "color": "#ED6C02"
        }
      },
      "descendants": {
        "alert-icon": {
          "fill": "#ED6C02",
          "iconFontName": "alert-triangle"
        },
        "alert-title": {
          "fill": "#ED6C02"
        },
        "alert-message": {
          "fill": "#ED6C02"
        }
      }
    },
    {
      "id": "alert-base-error",
      "type": "ref",
      "ref": "alert-base",
      "x": 600,
      "y": 150,
      "reusable": true,
      "fill": "#FFEBEE",
      "stroke": {
        "thickness": 1,
        "fill": {
          "type": "color",
          "color": "#D32F2F"
        }
      },
      "descendants": {
        "alert-icon": {
          "fill": "#D32F2F",
          "iconFontName": "x-circle"
        },
        "alert-title": {
          "fill": "#D32F2F"
        },
        "alert-message": {
          "fill": "#D32F2F"
        }
      }
    }
  ]
}
