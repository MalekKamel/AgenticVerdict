{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "input-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 8,
      "padding": 12,
      "cornerRadius": 8,
      "height": 40,
      "fill": "#FFFFFF",
      "stroke": {
        "thickness": 1,
        "fill": "#E0E0E0"
      },
      "children": [
        {
          "id": "input-text",
          "type": "text",
          "reusable": false,
          "fill": "#212121",
          "content": "Enter text...",
          "fontSize": 16,
          "fontWeight": 400,
          "textAlign": "left"
        }
      ],
      "x": 0,
      "y": 0
    },
    {
      "id": "input-base-size-sm",
      "type": "ref",
      "ref": "input-base",
      "x": 0,
      "y": 300,
      "height": 32,
      "padding": 8
    },
    {
      "id": "input-base-size-md",
      "type": "ref",
      "ref": "input-base",
      "x": 0,
      "y": 400,
      "height": 40,
      "padding": [8, 12]
    },
    {
      "id": "input-base-size-lg",
      "type": "ref",
      "ref": "input-base",
      "x": 0,
      "y": 500,
      "height": 48,
      "padding": 16
    },
    {
      "id": "input-base-state-default",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 0
    },
    {
      "id": "input-base-state-error",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 100,
      "stroke": {
        "thickness": 2,
        "fill": "#D32F2F"
      }
    },
    {
      "id": "input-base-state-warning",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 200,
      "stroke": {
        "thickness": 2,
        "fill": "#FFA000"
      }
    },
    {
      "id": "input-base-state-success",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 300,
      "stroke": {
        "thickness": 2,
        "fill": "#2E7D32"
      }
    },
    {
      "id": "input-base-state-disabled",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 400,
      "fill": "#F5F5F5",
      "opacity": 0.6,
      "enabled": false
    },
    {
      "id": "input-base-state-readonly",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 500,
      "fill": "#FAFAFA",
      "enabled": false
    },
    {
      "id": "input-base-state-focus",
      "type": "ref",
      "ref": "input-base",
      "x": 500,
      "y": 600,
      "stroke": {
        "thickness": 2,
        "fill": "#1976D2"
      },
      "effect": [
        {
          "type": "shadow",
          "offset": {
            "x": 0,
            "y": 0
          },
          "blur": 4,
          "spread": 2,
          "color": "rgba(25, 118, 210, 0.4)"
        }
      ]
    }
  ]
}
