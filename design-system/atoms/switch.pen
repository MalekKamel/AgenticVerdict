{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "switch-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 12,
      "children": [
        {
          "id": "switch-track",
          "type": "frame",
          "reusable": false,
          "padding": 2,
          "cornerRadius": 9999,
          "height": 24,
          "width": 44,
          "fill": "#BDBDBD",
          "children": [
            {
              "id": "switch-thumb",
              "type": "frame",
              "reusable": false,
              "cornerRadius": 9999,
              "height": 20,
              "width": 20,
              "fill": "#FFFFFF",
              "x": 0,
              "y": 0
            }
          ]
        },
        {
          "id": "switch-label",
          "type": "text",
          "reusable": false,
          "fill": "#212121",
          "content": "Enable feature",
          "fontSize": 16,
          "textAlign": "left"
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    },
    {
      "id": "switch-base-size-sm",
      "type": "ref",
      "ref": "switch-base",
      "x": 0,
      "y": 300,
      "name": "Switch/Small",
      "reusable": true,
      "descendants": {
        "switch-track": {
          "width": 36,
          "height": 20
        },
        "switch-thumb": {
          "width": 16,
          "height": 16
        },
        "switch-label": {
          "fontSize": 14
        }
      }
    },
    {
      "id": "switch-base-size-md",
      "type": "ref",
      "ref": "switch-base",
      "x": 0,
      "y": 400,
      "name": "Switch/Medium",
      "reusable": true,
      "descendants": {
        "switch-track": {
          "width": 44,
          "height": 24
        },
        "switch-thumb": {
          "width": 20,
          "height": 20
        },
        "switch-label": {
          "fontSize": 16
        }
      }
    },
    {
      "id": "switch-base-size-lg",
      "type": "ref",
      "ref": "switch-base",
      "x": 0,
      "y": 500,
      "name": "Switch/Large",
      "reusable": true,
      "descendants": {
        "switch-track": {
          "width": 52,
          "height": 28
        },
        "switch-thumb": {
          "width": 24,
          "height": 24
        },
        "switch-label": {
          "fontSize": 18
        }
      }
    },
    {
      "id": "switch-base-state-off",
      "type": "ref",
      "ref": "switch-base",
      "x": 500,
      "y": 0,
      "name": "Switch/Off",
      "reusable": true
    },
    {
      "id": "switch-base-state-on",
      "type": "ref",
      "ref": "switch-base",
      "x": 500,
      "y": 100,
      "name": "Switch/On",
      "reusable": true,
      "descendants": {
        "switch-track": {
          "fill": "#1976D2"
        },
        "switch-thumb": {
          "fill": "#FFFFFF"
        }
      }
    },
    {
      "id": "switch-base-state-disabled",
      "type": "ref",
      "ref": "switch-base",
      "x": 500,
      "y": 200,
      "name": "Switch/Disabled",
      "opacity": 0.5,
      "enabled": false,
      "descendants": {
        "switch-track": {
          "fill": "#E0E0E0"
        },
        "switch-thumb": {
          "fill": "#BDBDBD"
        },
        "switch-label": {
          "fill": "#9E9E9E"
        }
      }
    }
  ]
}
