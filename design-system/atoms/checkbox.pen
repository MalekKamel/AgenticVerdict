{
  "version": "2.10",
  "variables": {},
  "children": [
    {
      "id": "checkbox-base",
      "type": "frame",
      "reusable": true,
      "layout": "horizontal",
      "gap": 8,
      "children": [
        {
          "id": "checkbox-box",
          "type": "frame",
          "reusable": false,
          "cornerRadius": 4,
          "height": 20,
          "width": 20,
          "fill": "#FFFFFF",
          "stroke": {
            "thickness": 1,
            "fill": {
              "type": "color",
              "color": "#E0E0E0"
            }
          },
          "children": [
            {
              "id": "checkbox-check",
              "type": "text",
              "reusable": false,
              "x": 0,
              "y": 0,
              "content": "\u2713",
              "fontSize": 12,
              "fill": "#1976D2"
            }
          ]
        },
        {
          "id": "checkbox-label",
          "type": "text",
          "reusable": false,
          "fill": "#212121",
          "content": "Checkbox label",
          "fontSize": 16,
          "textAlign": "left"
        }
      ],
      "x": 0,
      "y": 0,
      "width": "fit_content(0)",
      "height": "fit_content(0)"
    },
    {
      "id": "checkbox-base-state-unchecked",
      "type": "ref",
      "ref": "checkbox-base",
      "x": 500,
      "y": 0,
      "name": "Checkbox/Unchecked",
      "reusable": true
    },
    {
      "id": "checkbox-base-state-checked",
      "type": "ref",
      "ref": "checkbox-base",
      "x": 500,
      "y": 100,
      "name": "Checkbox/Checked",
      "reusable": true,
      "box": {
        "fill": "#1976D2",
        "stroke": {
          "color": "#1976D2",
          "thickness": 1
        }
      },
      "check": {
        "visible": true
      }
    },
    {
      "id": "checkbox-base-state-indeterminate",
      "type": "ref",
      "ref": "checkbox-base",
      "x": 500,
      "y": 200,
      "name": "Checkbox/Indeterminate",
      "reusable": true,
      "box": {
        "fill": "#1976D2",
        "stroke": {
          "color": "#1976D2",
          "thickness": 1
        }
      },
      "indicator": {
        "type": "dash",
        "width": 10,
        "height": 2,
        "fill": "#FFFFFF"
      }
    },
    {
      "id": "checkbox-base-state-disabled",
      "type": "ref",
      "ref": "checkbox-base",
      "x": 500,
      "y": 300,
      "name": "Checkbox/Disabled",
      "opacity": 0.5,
      "interactive": false,
      "box": {
        "fill": "#F5F5F5",
        "stroke": {
          "color": "#BDBDBD",
          "thickness": 1
        }
      },
      "label": {
        "fill": "#9E9E9E"
      }
    }
  ]
}