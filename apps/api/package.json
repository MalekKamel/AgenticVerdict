{
  "name": "@agenticverdict/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./trpc": "./src/trpc/router-export.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:vite": "vite build",
    "dev": "API_PORT_AUTO_INCREMENT=1 node --import tsx src/cli.ts",
    "lint": "eslint .",
    "start": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agenticverdict/agent-runtime": "workspace:*",
    "@agenticverdict/config": "workspace:*",
    "@agenticverdict/core": "workspace:*",
    "@agenticverdict/database": "workspace:*",
    "@agenticverdict/i18n": "workspace:*",
    "@agenticverdict/observability": "workspace:*",
    "@agenticverdict/report-generator": "workspace:*",
    "@agenticverdict/types": "workspace:*",
    "@agenticverdict/worker": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@trpc/server": "^11.16.0",
    "@upstash/redis": "^1.37.0",
    "bullmq": "^5.40.0",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "ioredis": "^5.5.0",
    "jose": "^5.10.0",
    "superjson": "^2.2.6",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@agenticverdict/testing": "workspace:*",
    "@types/node": "^20.19.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.8",
    "vitest": "^3.0.0"
  }
