# Copy to .env.local (gitignored) or export in your shell when needed.

# Default in main: http://localhost:3000/ — same port as `pnpm --filter @agenticverdict/frontend dev`
# DESKTOP_RENDERER_URL=http://127.0.0.1:3000/

# Optional: load a built `index.html` instead of the dev server (production experiments)
# DESKTOP_RENDERER_STATIC=/absolute/path/to/apps/frontend/dist/client/index.html

# Absolute path to node when not using PATH or bundled resources/node (packaged builds)
# DESKTOP_NODE_BINARY=/usr/local/bin/node

# Embedded-server error UX when Node cannot be resolved (optional)
# DESKTOP_FALLBACK_BROWSER_URL=https://app.example.com/
# DESKTOP_DOCS_URL=https://internal.example.com/docs/desktop

# Packaged builds: generic electron-updater feed base (latest.yml + artifacts)
# DESKTOP_UPDATES_URL=https://releases.example.com/desktop
