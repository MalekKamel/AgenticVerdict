/**
 * Component tests for InsightListPage
 */

import { describe, it, expect, vi, beforeEach } from 'vitest';
import { render, screen, waitFor, fireEvent } from '@testing-library/react';
import { QueryClient, QueryClientProvider } from '@tanstack/react-query';
import { MantineProvider } from '@mantine/core';
import { InsightListPage } from '../InsightListPage';
import * as insightApi from '../../api/insight-api';

// Mock the API hooks
vi.mock('../../api/insight-api', () => ({
  useInsightList: vi.fn(),
  useInsightDelete: vi.fn(),
  useInsightRun: vi.fn(),
}));

// Mock router hooks
vi.mock('@/router/hooks/useSearch', () => ({
  useSearch: vi.fn(() => ({
    status: undefined,
    search: '',
    page: '1',
  })),
}));

vi.mock('@/i18n/navigation', () => ({
  useRouter: vi.fn(() => ({
    push: vi.fn(),
    replace: vi.fn(),
  })),
}));

vi.mock('@/i18n/react', () => ({
  useTranslations: vi.fn(() => {
    const t = (key: string) => key;
    return { t, i18n: { language: 'en' } };
  }),
}));

vi.mock('@/features/shell/ui/app-shell-context', () => ({
  useAppShellHeader: vi.fn(() => ({
    setHeaderOptions: vi.fn(),
    clearHeaderOptions: vi.fn(),
  })),
}));

const mockInsights = {
  insights: [
    {
      id: 'insight-1',
      name: 'SEO Performance Insight',
      enabled: true,
      connectors: [{ connectorId: 'ga4', metricIds: ['sessions', 'bounceRate'] }],
      createdAt: new Date('2024-01-15').toISOString(),
      updatedAt: new Date('2024-01-20').toISOString(),
    },
    {
      id: 'insight-2',
      name: 'Social Media Analytics',
      enabled: false,
      connectors: [{ connectorId: 'meta', metricIds: ['impressions', 'engagement'] }],
      createdAt: new Date('2024-01-10').toISOString(),
      updatedAt: new Date('2024-01-18').toISOString(),
    },
  ],
  total: 2,
  page: 1,
  pageSize: 20,
};

const createWrapper = () => {
  const queryClient = new QueryClient({
    defaultOptions: {
      queries: {
        retry: false,
      },
    },
  });
  
  return ({ children }: { children: React.ReactNode }) => (
    <QueryClientProvider client={queryClient}>
      <MantineProvider>
        {children}
      </MantineProvider>
    </QueryClientProvider>
  );
};

describe('InsightListPage', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it('should render loading state initially', () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: undefined,
      isLoading: true,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    expect(screen.getByText('insights.list.loading')).toBeInTheDocument();
  });

  it('should render insight cards when data is loaded', async () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      expect(screen.getByText('SEO Performance Insight')).toBeInTheDocument();
      expect(screen.getByText('Social Media Analytics')).toBeInTheDocument();
    });
  });

  it('should display status badges for each insight', async () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      expect(screen.getByText('insights.status.enabled')).toBeInTheDocument();
      expect(screen.getByText('insights.status.disabled')).toBeInTheDocument();
    });
  });

  it('should render "New Insight" button', async () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      expect(screen.getByText('insights.list.newInsight')).toBeInTheDocument();
    });
  });

  it('should render filter inputs', async () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      expect(screen.getByPlaceholderText('insights.list.searchPlaceholder')).toBeInTheDocument();
      expect(screen.getByText('insights.list.filters.status')).toBeInTheDocument();
    });
  });

  it('should show action menu for each insight', async () => {
    const mockDelete = vi.fn();
    const mockRun = vi.fn();
    
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);
    
    vi.mocked(insightApi.useInsightDelete).mockReturnValue({
      mutate: mockDelete,
    } as any);
    
    vi.mocked(insightApi.useInsightRun).mockReturnValue({
      mutate: mockRun,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      const actionButtons = screen.getAllByRole('button', { name: /dots/i });
      expect(actionButtons.length).toBeGreaterThan(0);
    });
  });

  it('should handle empty state', () => {
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: { insights: [], total: 0, page: 1, pageSize: 20 },
      isLoading: false,
      isError: false,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    expect(screen.getByText('insights.list.emptyState.title')).toBeInTheDocument();
  });

  it('should handle error state', () => {
    const mockError = new Error('Failed to load insights');
    
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: undefined,
      isLoading: false,
      isError: true,
      error: mockError,
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    expect(screen.getByText('insights.list.error')).toBeInTheDocument();
  });

  it('should navigate to create wizard when "New Insight" is clicked', async () => {
    const mockPush = vi.fn();
    
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);
    
    vi.mocked('@/i18n/navigation').useRouter.mockReturnValue({
      push: mockPush,
      replace: vi.fn(),
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      const newButton = screen.getByText('insights.list.newInsight');
      fireEvent.click(newButton);
    });

    expect(mockPush).toHaveBeenCalledWith('/dashboard/insights/new');
  });

  it('should navigate to detail page when viewing insight', async () => {
    const mockPush = vi.fn();
    
    vi.mocked(insightApi.useInsightList).mockReturnValue({
      data: mockInsights,
      isLoading: false,
      isError: false,
    } as any);
    
    vi.mocked('@/i18n/navigation').useRouter.mockReturnValue({
      push: mockPush,
      replace: vi.fn(),
    } as any);

    render(<InsightListPage />, { wrapper: createWrapper() });

    await waitFor(() => {
      const viewButtons = screen.getAllByText('insights.list.actions.viewDetails');
      fireEvent.click(viewButtons[0]);
    });

    expect(mockPush).toHaveBeenCalledWith('/dashboard/insights/insight-1');
  });
});
