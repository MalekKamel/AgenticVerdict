    "@agenticverdict/data-connectors": "workspace:*",
    "@agenticverdict/desktop-ipc": "workspace:*",
    "@agenticverdict/i18n": "workspace:*",
    "@agenticverdict/types": "workspace:*",
    "@agenticverdict/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^7.15.2",
    "@mantine/dates": "^7.17.8",
    "@mantine/form": "^7.15.2",
    "@mantine/hooks": "^7.15.2",
    "@mantine/notifications": "^9.1.1",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router": "^1.168.21",
    "@tanstack/react-start": "^1.167.39",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/router-plugin": "^1.167.22",
    "@tanstack/store": "^0.9.3",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "dayjs": "^1.11.20",
    "intl-messageformat": "^11.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "react-pdf": "^10.4.1",
    "superjson": "^2.2.6",
    "web-vitals": "^4.2.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
