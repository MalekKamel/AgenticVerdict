{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".next/**", "!.next/cache/**"]
    },
    "build:vite": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "outputs": []
    },
    "test:integration": {
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "outputs": ["test-results/**", "playwright-report/**"]
    },
    "typecheck": {}
  }
}
