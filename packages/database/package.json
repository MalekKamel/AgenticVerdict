{
  "name": "@agenticverdict/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:test": "tsx scripts/seed-test.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@agenticverdict/types": "workspace:*",
    "@agenticverdict/config": "workspace:*",
    "@agenticverdict/core": "workspace:*",
    "@agenticverdict/observability": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
