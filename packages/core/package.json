{
  "name": "@agenticverdict/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tenant/*": "./src/tenant/*.ts",
    "./tenant-context": "./src/tenant-context.ts",
    "./storage/*": "./src/storage/*.ts",
    "./storage": "./src/storage/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agenticverdict/config": "workspace:*",
    "@agenticverdict/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@trpc/client": "^11.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
