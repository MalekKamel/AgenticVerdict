{
  "name": "@agenticverdict/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./formatters": "./src/formatters.ts",
    "./locales": "./src/locales/index.ts",
    "./language-detection": "./src/language-detection.ts",
    "./load-messages": "./src/load-messages.ts",
    "./message-utils": "./src/message-utils.ts",
    "./rtl": "./src/rtl.ts",
    "./types": "./src/types/generated.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "generate:types": "tsx src/scripts/generate-types.ts",
    "lint": "eslint .",
    "prebuild": "pnpm generate:types",
    "pretypecheck": "pnpm generate:types",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:dead-keys": "tsx src/scripts/find-dead-keys.ts"
  },
  "dependencies": {
    "@agenticverdict/config": "workspace:*",
    "@agenticverdict/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "eslint": "^9.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
