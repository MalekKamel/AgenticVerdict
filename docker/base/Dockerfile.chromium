# Pre-installed Chromium stack for worker PDF/Playwright. Tag as agenticverdict/chromium-base:local (see docs/docker/container-images.md).
ARG NODE_VERSION=20

FROM node:${NODE_VERSION}-bookworm-slim AS chromium-base

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
    && apt-get install -y --no-install-recommends \
      openssl \
      ca-certificates \
      wget \
      chromium \
      fonts-liberation \
      fonts-noto-core \
      libasound2 \
      libatk-bridge2.0-0 \
      libatk1.0-0 \
      libatspi2.0-0 \
      libcups2 \
      libdbus-1-3 \
      libdrm2 \
      libgbm1 \
      libgtk-3-0 \
      libnspr4 \
      libnss3 \
      libwayland-client0 \
      libxcomposite1 \
      libxdamage1 \
      libxfixes3 \
      libxkbcommon0 \
      libxrandr2 \
      xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Same UID/GID as deps image and API runner (see Dockerfile.deps / docker-build remediation V3).
RUN groupadd --gid 1001 appuser \
  && useradd --uid 1001 --gid appuser --shell=/bin/bash --create-home appuser

RUN chromium --version

ARG CHROMIUM_TAG=bookworm
LABEL org.agenticverdict.chromium.node-version="${NODE_VERSION}" \
      org.agenticverdict.chromium.base-tag="${CHROMIUM_TAG}"
