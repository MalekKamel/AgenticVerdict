{
  "version": "2.11",
  "children": [],
  "variables": {
    "--global-color-blue-500": {
      "type": "color",
      "value": "#3b82f6"
    },
    "--global-color-blue-700": {
      "type": "color",
      "value": "#1d4ed8"
    },
    "--global-color-neutral-100": {
      "type": "color",
      "value": "#f3f4f6"
    },
    "--global-color-neutral-500": {
      "type": "color",
      "value": "#6b7280"
    },
    "--global-color-neutral-900": {
      "type": "color",
      "value": "#111827"
    },
    "--global-spacing-lg": {
      "type": "number",
      "value": 24
    },
    "--global-spacing-md": {
      "type": "number",
      "value": 16
    },
    "--global-spacing-sm": {
      "type": "number",
      "value": 8
    },
    "--global-spacing-xl": {
      "type": "number",
      "value": 32
    },
    "--global-spacing-xs": {
      "type": "number",
      "value": 4
    },
    "--global-color-background": {
      "type": "color",
      "value": "#ffffff"
    },
    "--global-color-error": {
      "type": "color",
      "value": "#ef4444"
    },
    "--global-color-foreground": {
      "type": "color",
      "value": "#111827"
    },
    "--global-color-primary": {
      "type": "color",
      "value": "#3b82f6"
    },
    "--global-color-secondary": {
      "type": "color",
      "value": "#8b5cf6"
    },
    "--global-color-success": {
      "type": "color",
      "value": "#10b981"
    },
    "--global-color-warning": {
      "type": "color",
      "value": "#f59e0b"
    },
    "--global-radius-lg": {
      "type": "number",
      "value": 12
    },
    "--global-radius-md": {
      "type": "number",
      "value": 8
    },
    "--global-radius-sm": {
      "type": "number",
      "value": 4
    },
    "--global-shadow-lg": {
      "type": "string",
      "value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)"
    },
    "--global-shadow-md": {
      "type": "string",
      "value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)"
    },
    "--global-shadow-sm": {
      "type": "string",
      "value": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)"
    },
    "--global-color-focus-ring": {
      "type": "color",
      "value": "#3b82f680"
    },
    "--global-motion-duration-fast": {
      "type": "number",
      "value": 150
    },
    "--global-motion-duration-medium": {
      "type": "number",
      "value": 300
    },
    "--global-motion-duration-slow": {
      "type": "number",
      "value": 500
    },
    "--brand-color-primary": {
      "type": "color",
      "value": "#3b82f6"
    },
    "--brand-color-secondary": {
      "type": "color",
      "value": "#8b5cf6"
    },
    "--brand-font-family-primary": {
      "type": "string",
      "value": "Inter, sans-serif"
    },
    "--button-primary-bg": {
      "type": "color",
      "value": "$--brand-color-primary"
    },
    "--button-primary-fg": {
      "type": "color",
      "value": "#ffffff"
    },
    "--button-secondary-bg": {
      "type": "color",
      "value": "$--brand-color-secondary"
    },
    "--button-secondary-fg": {
      "type": "color",
      "value": "#ffffff"
    },
    "--button-test": {
      "type": "color",
      "value": "$--global-color-primary"
    },
    "--alert-warning-bg": {
      "type": "color",
      "value": "$--global-color-warning"
    },
    "--input-border-error": {
      "type": "color",
      "value": "$--global-color-error"
    },
    "--button-padding-x": {
      "type": "number",
      "value": "$--global-spacing-md"
    },
    "--button-padding-y": {
      "type": "number",
      "value": "$--global-spacing-sm"
    },
    "--button-radius": {
      "type": "number",
      "value": "$--global-radius-md"
    },
    "--card-padding": {
      "type": "number",
      "value": "$--global-spacing-md"
    },
    "--card-radius": {
      "type": "number",
      "value": "$--global-radius-md"
    },
    "--card-shadow": {
      "type": "string",
      "value": "$--global-shadow-md"
    },
    "--formfield-gap": {
      "type": "number",
      "value": "$--global-spacing-sm"
    },
    "--input-radius": {
      "type": "number",
      "value": "$--global-radius-md"
    },
    "--popover-shadow": {
      "type": "string",
      "value": "$--global-shadow-lg"
    },
    "--global-font-weight-bold": {
      "type": "string",
      "value": "700"
    },
    "--global-font-weight-medium": {
      "type": "string",
      "value": "500"
    },
    "--global-font-weight-normal": {
      "type": "string",
      "value": "400"
    },
    "--global-font-weight-semibold": {
      "type": "string",
      "value": "600"
    },
    "--global-line-height-normal": {
      "type": "number",
      "value": 1.5
    },
    "--global-line-height-relaxed": {
      "type": "number",
      "value": 1.75
    },
    "--global-line-height-tight": {
      "type": "number",
      "value": 1.25
    },
    "--global-radius-pill": {
      "type": "number",
      "value": 999
    }
  }
}