# Copy to .env.local for local development (not committed).

# Node runtime (development | production | test)
NODE_ENV=development

# PostgreSQL — matches root docker-compose.yml (Postgres 16, db agenticverdict, user/pass postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agenticverdict

# Redis (TCP) — optional for now; typical URL when using local Redis from compose (future BullMQ / ioredis)
REDIS_URL=redis://localhost:6379

# Upstash Redis (REST) — optional; used by packages/database when both are set (distributed cache)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Directory for company JSON configs (packages/config); relative to cwd unless absolute
COMPANY_CONFIG_DIR=configs/companies

# Optional: watch config dir and invalidate cached company JSON (packages/config hot-reload)
# AGENTICVERDICT_CONFIG_HOT_RELOAD=1

# Optional: per-tenant JSON merge patch overrides (packages/config env-merge). Suffix uses UUID with hyphens → underscores.
# AGENTICVERDICT_COMPANY_MERGE_a1b2c3d4_e5f6_4a5b_8c9d_0e1f2a3b4c5d={"localization":{"language":"en"}}
