# Copy to .env.local for local development (not committed).

# Node runtime (development | production | test)
NODE_ENV=development
# Runtime policy environment (development | test | staging | production)
AGENTICVERDICT_RUNTIME_ENV=development

# Frontend runtime env contract (production/staging fail-closed)
# Browser-visible API URL used by frontend bundle and browser tRPC calls.
# Required in production-like runtime.
# VITE_PUBLIC_API_URL=http://localhost:4000
# Frontend SSR/internal API URL used by server-side loaders/actions inside web container.
# Required in production-like runtime.
# API_URL=http://api:4000
# Required UUID used by /$locale home loader contract in current implementation.
# VITE_PUBLIC_DEFAULT_TENANT_ID=11111111-1111-4111-8111-111111111111

# PostgreSQL — matches root docker-compose.yml (Postgres 16, db agenticverdict, user/pass postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agenticverdict

# Redis (TCP) — BullMQ in apps/worker and optional enqueue/repeatable jobs in apps/api use ioredis; Upstash REST alone is not sufficient for queues
REDIS_URL=redis://localhost:6379

# Upstash Redis (REST) — optional; used by packages/database when both are set (distributed cache)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Directory for tenant JSON configs (packages/config); relative to cwd unless absolute
TENANT_CONFIG_DIR=configs/tenants

# Web (apps/frontend) — comma-separated base hostnames for subdomain → tenant UUID (`trpc.tenant.resolveSlug`), e.g. `localhost` maps `acme.localhost` → slug `acme`
# VITE_PUBLIC_TENANT_BASE_DOMAINS=localhost

# Frontend (apps/frontend) — public support mailbox on `/…/auth/help` (overrides default in locale messages when set)
# VITE_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Optional: watch config dir and invalidate cached tenant JSON (packages/config hot-reload)
# AGENTICVERDICT_CONFIG_HOT_RELOAD=1

# Optional: per-tenant JSON merge patch overrides (packages/config env-merge). Suffix uses UUID with hyphens → underscores.
# AGENTICVERDICT_TENANT_MERGE_a1b2c3d4_e5f6_4a5b_8c9d_0e1f2a3b4c5d={"localization":{"language":"en"}}

# HTTP API (apps/api) — HS256 secret, min 8 characters. JWT `roles` claim drives RBAC:
# - Report reads: include "analyst" and/or "reports:read"
# - Report create/upload: include "reports:write" and/or "admin"
# JWT_SECRET=replace-with-long-random-secret
# API_PORT=4000

# Browser telemetry ingest (POST /api/v1/telemetry/ingest) — required in production (NODE_ENV=production).
# Must match the web client `VITE_PUBLIC_TELEMETRY_INGEST_TOKEN` when using authenticated ingest.
# TELEMETRY_INGEST_SECRET=replace-with-long-random-shared-key
# Optional: fraction (0–1) of accepted envelopes that emit structured INFO logs (reduces log volume; default 1).
# TELEMETRY_INGEST_LOG_SAMPLE_RATE=0.25

# Public app URL for report links in worker emails
# APP_URL=https://app.example.com

# Email (apps/worker) — Resend takes precedence when both keys are set
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=reports@yourdomain.com
# SENDGRID_API_KEY=SG.xxxxxxxx
# SENDGRID_FROM_EMAIL=reports@yourdomain.com
# SENDGRID_FROM_NAME=AgenticVerdict Reports

# Runtime mock/stub policy (single source of truth)
# AGENTICVERDICT_MOCK_MODE=off
# AGENTICVERDICT_MOCK_CONNECTORS=meta,ga4
# AGENTICVERDICT_MOCK_SCENARIO=normal
# AGENTICVERDICT_STUB_REPORT_FORMATS=0
# AGENTICVERDICT_STUB_EMAIL_DELIVERY=0
# Frontend auth mode: real (default) | mock (dev/test only)
# VITE_PUBLIC_AUTH_API_MODE=real

# Vitest: skip Playwright PDF integration (default runs when Chromium is installed via `pnpm exec playwright install chromium`)
# SKIP_PLAYWRIGHT_PDF_TESTS=1

# LLM Configuration (GLM/ZhipuAI) — used for AI agent analysis and insights
# GLM_API_KEY=your-glm-api-key-here
# GLM_API_BASE_URL=https://api.z.ai/api/anthropic
# GLM_MODEL=glm-4.5
# GLM_TIMEOUT=30000

# Optional: Anthropic Claude API (primary fallback)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: OpenAI API (secondary fallback)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# Connector mock mode (selective list applies only when AGENTICVERDICT_MOCK_MODE=selective)
# AGENTICVERDICT_MOCK_SEED=42001
# AGENTICVERDICT_MOCK_SCENARIO=normal
